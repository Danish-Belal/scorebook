# ═══════════════════════════════════════════════════════════
#  ScoreBook Frontend — Environment Variables
#  Copy this to .env.local for development
#  For production, set NEXT_PUBLIC_API_URL to your real backend URL
# ═══════════════════════════════════════════════════════════

# Backend API URL
# Development (local backend):
NEXT_PUBLIC_API_URL=http://localhost:3001

# Production (replace with your deployed backend):
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
