# ═══════════════════════════════════════════════════════════
#  ScoreBook Frontend — Environment Variables
#  Copy this to .env.local for development
#  For production, set NEXT_PUBLIC_API_URL to your real backend URL
# ═══════════════════════════════════════════════════════════

# Backend API URL (Express on PORT, default 3001)
# REQUIRED for OAuth: sign-in links go to ${NEXT_PUBLIC_API_URL}/auth/github|google
# If this is wrong or points to port 3000 (Next.js), you get 404 on GitHub/Google login.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Production (replace with your deployed backend):
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
