{
  "name": "scorebook-backend",
  "version": "1.0.0",
  "description": "ScoreBook — Developer Intelligence Platform Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev":              "ts-node-dev --respawn --transpile-only src/index.ts",
    "build":            "tsc",
    "start":            "node dist/index.js",
    "worker:fetch":     "ts-node-dev --respawn --transpile-only src/workers/fetchWorker.ts",
    "worker:score":     "ts-node-dev --respawn --transpile-only src/workers/scoreWorker.ts",
    "worker:refresh":   "ts-node-dev --respawn --transpile-only src/workers/refreshWorker.ts",
    "migrate":          "drizzle-kit push",
    "test":             "jest",
    "test:unit":        "jest tests/unit --passWithNoTests"
  },
  "dependencies": {
    "express":                  "^4.18.2",
    "cors":                     "^2.8.5",
    "helmet":                   "^7.1.0",
    "morgan":                   "^1.10.0",
    "compression":              "^1.7.4",
    "express-rate-limit":       "^7.1.5",
    "passport":                 "^0.7.0",
    "passport-github2":         "^0.1.12",
    "passport-google-oauth20":  "^2.0.0",
    "jsonwebtoken":             "^9.0.2",
    "cookie-parser":            "^1.4.6",
    "drizzle-orm":              "^0.30.10",
    "@neondatabase/serverless":  "^0.9.3",
    "ioredis":                  "^5.3.2",
    "bullmq":                   "^5.1.1",
    "zod":                      "^3.22.4",
    "dotenv":                   "^16.4.5",
    "axios":                    "^1.6.5",
    "cheerio":                  "^1.0.0-rc.12",
    "node-cron":                "^3.0.3",
    "winston":                  "^3.11.0",
    "ws":                       "^8.16.0"
  },
  "devDependencies": {
    "typescript":                   "^5.4.5",
    "ts-node-dev":                  "^2.0.0",
    "ts-node":                      "^10.9.2",
    "@types/express":               "^4.17.21",
    "@types/node":                  "^20.12.7",
    "@types/cors":                  "^2.8.17",
    "@types/morgan":                "^1.9.9",
    "@types/compression":           "^1.7.5",
    "@types/passport":              "^1.0.16",
    "@types/passport-github2":      "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/jsonwebtoken":          "^9.0.5",
    "@types/cookie-parser":         "^1.4.6",
    "@types/ws":                    "^8.5.10",
    "@types/node-cron":             "^3.0.11",
    "drizzle-kit":                  "^0.21.4",
    "jest":                         "^29.7.0",
    "@types/jest":                  "^29.5.11",
    "ts-jest":                      "^29.1.1"
  }
}
