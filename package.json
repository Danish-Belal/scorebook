{
  "name": "scorebook-backend",
  "version": "1.0.0",
  "description": "ScoreBook — Developer Intelligence Platform Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev:all": "concurrently -k -n api,fetch,score,refresh,web -c blue,green,yellow,magenta,cyan \"npm run dev\" \"npm run worker:fetch\" \"npm run worker:score\" \"npm run worker:refresh\" \"npm run dev --prefix scorebook-frontend\"",
    "stop:all": "bash scripts/stop-dev-all.sh",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker:fetch": "ts-node-dev --respawn --transpile-only src/workers/fetchWorker.ts",
    "worker:score": "ts-node-dev --respawn --transpile-only src/workers/scoreWorker.ts",
    "worker:refresh": "ts-node-dev --respawn --transpile-only src/workers/refreshWorker.ts",
    "worker:snapshot": "ts-node-dev --respawn --transpile-only src/workers/snapshotWorker.ts",
    "worker:fetch:prod": "node dist/workers/fetchWorker.js",
    "worker:score:prod": "node dist/workers/scoreWorker.js",
    "worker:refresh:prod": "node dist/workers/refreshWorker.js",
    "worker:snapshot:prod": "node dist/workers/snapshotWorker.js",
    "diagnose:score": "ts-node --transpile-only scripts/diagnose-score.ts",
    "migrate": "drizzle-kit push",
    "test": "jest",
    "test:unit": "jest tests/unit --passWithNoTests"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.3",
    "axios": "^1.6.5",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.1.1",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/passport": "^1.0.16",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/ws": "^8.5.10",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.21.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
