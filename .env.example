# ═══════════════════════════════════════════════════════════════════
#  ScoreBook — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ═══════════════════════════════════════════════════════════════════

# ── Database (Neon) ─────────────────────────────────────────────────
# 1. Go to https://neon.tech and create a free account
# 2. Create a new project called "scorebook"
# 3. Copy the connection string from Dashboard → Connection Details
# 4. Make sure to select "Pooled connection" and Node.js as the driver
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/scorebook?sslmode=require

# ── Redis (Upstash) ──────────────────────────────────────────────────
# 1. Go to https://upstash.com and create a free account
# 2. Create a new Redis database called "scorebook"
# 3. Copy the "UPSTASH_REDIS_URL" from the database details page
#    It looks like: rediss://default:xxxxx@xxxx.upstash.io:6379
REDIS_URL=rediss://default:your_token@your-db.upstash.io:6379

# ── JWT Secret ───────────────────────────────────────────────────────
# Generate one by running: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_hex_string_from_command_above
JWT_EXPIRES_IN=7d

# ── GitHub OAuth ─────────────────────────────────────────────────────
# 1. Go to https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Set Homepage URL: http://localhost:3000
# 4. Set Callback URL: http://localhost:3001/auth/github/callback
# 5. Copy Client ID and generate a Client Secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Google OAuth ──────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID → Web Application
# 4. Add http://localhost:3001/auth/google/callback as redirect URI
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── GitHub PAT (optional but recommended) ────────────────────────────
# Increases GitHub API rate limit from 60 to 5000 requests/hour
# Go to https://github.com/settings/tokens → Generate new token (classic)
# Required scopes: read:user, public_repo
GITHUB_PAT=github_pat_your_token_here

# ── App Settings (leave as-is for local dev) ─────────────────────────
PORT=3001
NODE_ENV=development
# Browser origin for CORS + post-OAuth redirect (Next.js URL)
FRONTEND_URL=http://localhost:3000
# Public URL of THIS API — OAuth redirect/callback URLs are built from this (no trailing slash needed)
# Must match GitHub "Authorization callback URL" and Google "Authorized redirect URIs" exactly
OAUTH_CALLBACK_BASE_URL=http://localhost:3001

# ── Worker Settings (leave as-is) ────────────────────────────────────
CODEFORCES_CONCURRENCY=3
LEETCODE_CONCURRENCY=2
GITHUB_CONCURRENCY=10
ATCODER_CONCURRENCY=2
GFG_CONCURRENCY=2
REFRESH_INTERVAL_HOURS=24
